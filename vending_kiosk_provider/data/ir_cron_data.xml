<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_cleanup_webhook_logs" model="ir.cron">
            <field name="name">Limpiar logs de webhooks</field>
            <field name="model_id" ref="model_vending_webhook_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_cleanup_old_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=3, minute=0, second=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
