{
  "info": {
    "_postman_id": "e92d8b26-9183-4f6f-bf42-2b489c5ad4fe",
    "name": "Vending Machine Webhooks (Split + API Key)",
    "description": "Coleccion para probar webhooks de vending con endpoints separados y autenticacion x-api-key por maquina.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Payment Status",
      "item": [
        {
          "name": "APPROVED",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{test_reference}}\",\n  \"status\": \"APPROVED\",\n  \"description\": \"PAYMENT_APPROVED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/vending/webhook/payment_status",
              "host": ["{{base_url}}"],
              "path": ["v1", "vending", "webhook", "payment_status"]
            }
          }
        },
        {
          "name": "REJECTED",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{test_reference}}\",\n  \"status\": \"REJECTED\",\n  \"description\": \"PAYMENT_REJECTED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/vending/webhook/payment_status",
              "host": ["{{base_url}}"],
              "path": ["v1", "vending", "webhook", "payment_status"]
            }
          }
        },
        {
          "name": "Unauthorized API key",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "invalid-key" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{test_reference}}\",\n  \"status\": \"APPROVED\",\n  \"description\": \"PAYMENT_APPROVED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/vending/webhook/payment_status",
              "host": ["{{base_url}}"],
              "path": ["v1", "vending", "webhook", "payment_status"]
            }
          }
        }
      ]
    },
    {
      "name": "Delivery Status",
      "item": [
        {
          "name": "SUCCESS",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{test_reference}}\",\n  \"status\": \"SUCCESS\",\n  \"description\": \"DELIVERY_SUCCESS\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/vending/webhook/delivery_status",
              "host": ["{{base_url}}"],
              "path": ["v1", "vending", "webhook", "delivery_status"]
            }
          }
        },
        {
          "name": "ERROR",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{test_reference}}\",\n  \"status\": \"ERROR\",\n  \"description\": \"DISPENSING_STUCK\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/vending/webhook/delivery_status",
              "host": ["{{base_url}}"],
              "path": ["v1", "vending", "webhook", "delivery_status"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8069" },
    { "key": "api_key", "value": "replace-with-machine-api-key" },
    { "key": "test_reference", "value": "replace-with-existing-reference" }
  ]
}
