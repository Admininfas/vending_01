    {
      "name": "Load Webhook - Batch (Array)",
      "item": [
        {
          "name": "Batch - Reposición completa de máquina",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type JSON', () => pm.response.to.have.header('Content-Type', 'application/json'));",
                  "const body = pm.response.json();",
                  "pm.test('Tiene campo results', () => pm.expect(body).to.have.property('results'));",
                  "pm.test('Todos los items procesados OK', () => {",
                  "  body.results.forEach((r, i) => {",
                  "    pm.expect(r.status, `item[${i}].status`).to.equal('ok');",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"machine\": \"{{test_machine_code}}\", \"slot\": 1, \"quantity\": 10 },\n  { \"machine\": \"{{test_machine_code}}\", \"slot\": 2, \"quantity\": 8  },\n  { \"machine\": \"{{test_machine_code}}\", \"slot\": 3, \"quantity\": 5  }\n]"
            },
            "url": {
              "raw": "{{base_url}}/v1/vending/webhook/load",
              "host": [ "{{base_url}}" ],
              "path": [ "v1", "vending", "webhook", "load" ]
            },
            "description": "Actualiza el stock de 3 slots en una sola llamada.\n\nEspera: HTTP 200, Content-Type application/json\nBody: { \"results\": [ { \"status\": \"ok\", ... }, ... ] }\n\nTodos los items deben tener status=ok."
          },
          "response": []
        },
        {
          "name": "Batch - Vaciar todos los slots",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Todos los items OK con quantity 0', () => {",
                  "  body.results.forEach((r, i) => {",
                  "    pm.expect(r.status, `item[${i}].status`).to.equal('ok');",
                  "    pm.expect(r.quantity, `item[${i}].quantity`).to.equal(0);",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"machine\": \"{{test_machine_code}}\", \"slot\": 1, \"quantity\": 0 },\n  { \"machine\": \"{{test_machine_code}}\", \"slot\": 2, \"quantity\": 0 },\n  { \"machine\": \"{{test_machine_code}}\", \"slot\": 3, \"quantity\": 0 }\n]"
            },
            "url": {
              "raw": "{{base_url}}/v1/vending/webhook/load",
              "host": [ "{{base_url}}" ],
              "path": [ "v1", "vending", "webhook", "load" ]
            },
            "description": "Vacía todos los slots en una sola llamada.\n\nEspera: HTTP 200\nResultado: stock.quant = 0 en cada slot."
          },
          "response": []
        },
        {
          "name": "Batch - Mix de máquinas",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Tiene results', () => pm.expect(body.results).to.be.an('array').with.lengthOf(2));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
