<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="vending_kiosk_ui.VendingProcessingScreen">
        <div class="o_self_vending_processing d-flex align-items-center justify-content-center h-100 w-100">
            
            <!-- Modal de confirmación de cancelación -->
            <div t-if="state.showCancelConfirmation" 
                 class="o_vending_cancel_modal position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
                 style="z-index: 9999; background-color: rgba(0,0,0,0.7);">
                <div class="card shadow-lg" style="max-width: 500px;">
                    <div class="card-body p-4 text-center">
                        <div class="mb-3">
                            <i class="fa fa-exclamation-triangle text-warning" style="font-size: 3rem;"/>
                        </div>
                        <h4 class="h5 fw-bold mb-3">¿Está seguro de cancelar?</h4>
                        <div class="text-start mb-4">
                            <p class="mb-2"><strong>Advertencia:</strong></p>
                            <ul class="text-muted small">
                                <li>Si ya realizó el pago, éste puede estar procesándose</li>
                                <li>Cancelar ahora puede causar problemas con su transacción</li>
                                <li>Le recomendamos esperar a que el pago se complete</li>
                            </ul>
                        </div>
                        <div class="d-flex gap-2 justify-content-center">
                            <button type="button" 
                                    class="btn btn-lg btn-primary px-4"
                                    t-on-click="dismissCancelConfirmation">
                                <i class="fa fa-clock-o me-2"/>
                                No, esperar el pago
                            </button>
                            <button type="button" 
                                    class="btn btn-lg btn-outline-danger px-4"
                                    t-on-click="confirmCancel">
                                <i class="fa fa-times me-2"/>
                                Sí, cancelar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card shadow-sm o_self_vending_card">
                <div class="card-body text-center p-4">
                    
                    <!-- Estado de error (fallback si no se pudo navegar) -->
                    <t t-if="state.paymentStatus === 'error'">
                        <div class="mb-4">
                            <i class="fa fa-exclamation-circle text-danger o_vending_status_icon"/>
                        </div>
                        <h3 class="h4 mb-2 text-danger">Ocurrió un Error</h3>
                        <p class="text-muted mb-4">
                            <t t-if="state.error" t-esc="state.error"/>
                            <t t-else="">El pago no pudo ser procesado. Por favor, intente nuevamente.</t>
                        </p>
                        <button type="button" class="btn btn-primary btn-lg px-4" t-on-click="regresar">
                            <i class="fa fa-arrow-left me-2"/>
                            Volver al menú
                        </button>
                    </t>
                    
                    <!-- QR expirado (fallback) -->
                    <t t-elif="state.qrRemaining &lt;= 0 and !state.loading and state.paymentStatus === 'pending'">
                        <div class="mb-4">
                            <i class="fa fa-clock-o text-warning o_vending_status_icon"/>
                        </div>
                        <h3 class="h4 mb-2 text-warning">QR Expirado</h3>
                        <p class="text-muted mb-4">El tiempo para pagar ha finalizado. Por favor, vuelva a intentarlo.</p>
                        <button type="button" class="btn btn-warning btn-lg px-4" t-on-click="regresar">
                            <i class="fa fa-refresh me-2"/>
                            Intentar nuevamente
                        </button>
                    </t>
                    
                    <!-- Estado normal - esperando pago -->
                    <t t-else="">
                        <!-- Loading spinner -->
                        <div class="mb-3" t-if="state.loading">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                        </div>

                        <h3 class="h4 mb-2">Escanee el QR para pagar</h3>
                        <p class="text-muted mb-4">Use su aplicación de pagos para escanear el código</p>

                        <!-- Sección del QR -->
                        <t t-if="state.qrUrl">
                            <div class="mb-3 p-3 border rounded-3 bg-white">
                                <div class="text-center">
                                    <img 
                                        t-att-src="state.qrUrl" 
                                        class="img-fluid rounded o_self_vending_qr" 
                                        alt="Código QR de pago"
                                    />
                                </div>
                                <!-- Timer -->
                                <t t-if="state.qrRemaining > 0">
                                    <div class="mt-3 text-center">
                                        <div class="d-inline-flex align-items-center px-3 py-2 rounded-pill o_vending_timer" 
                                             t-att-class="state.qrRemaining &lt;= 30 ? 'o_timer_warning' : 'bg-light'">
                                            <i class="fa fa-clock-o me-2" 
                                               t-att-class="state.qrRemaining &lt;= 30 ? 'text-warning' : 'text-muted'"/>
                                            <span class="fw-bold" 
                                                  t-att-class="state.qrRemaining &lt;= 30 ? 'text-warning' : 'text-dark'"
                                                  t-esc="formattedTime"/>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>

                        <!-- Producto seleccionado -->
                        <t t-if="product">
                            <div class="border rounded-3 p-3 bg-light">
                                <div class="row align-items-center">
                                    <div class="col-5">
                                        <img 
                                            class="img-fluid rounded-4 object-fit-cover o_vending_product_image" 
                                            t-attf-src="/web/image/product.template/#{product.product_tmpl_id?.id or product.id}/image_512?unique=#{product.write_date}"
                                            loading="lazy"
                                            t-att-alt="product.display_name"
                                        />
                                    </div>
                                    <div class="col-7 text-start">
                                        <h5 class="fw-bold mb-1 o_vending_product_name" t-esc="product.display_name"/>
                                        <div class="text-primary fw-bold o_vending_product_price mb-2" t-esc="formattedPrice"/>

                                        <!-- Descripción pública del producto -->
                                        <t t-if="product.public_description">
                                            <div class="mb-2 text-muted small" t-out="product.public_description"/>
                                        </t>

                                        <!-- Información del slot seleccionado -->
                                        <t t-if="state.selectedSlot">
                                            <div class="mt-2 pt-2 border-top">
                                                <span class="fw-semibold text-muted small" t-esc="state.selectedSlot.name"/>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </t>

                        <!-- Botón cancelar (aparece después de 10s) -->
                        <div class="mt-4" t-if="state.showBack">
                            <button type="button" class="btn btn-danger btn-lg px-4" t-on-click="regresar">
                                <i class="fa fa-times me-2"/>
                                Cancelar
                            </button>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>