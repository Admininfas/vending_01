<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Vending Slot: List View -->
    <record id="view_vending_slot_list" model="ir.ui.view">
        <field name="name">vending.slot.list</field>
        <field name="model">vending.slot</field>
        <field name="arch" type="xml">
            <list string="Slots de Expendedora" decoration-danger="is_fault_blocked">
                <field name="machine_id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="product_tmpl_id"/>
                <field name="current_stock" string="Stock"/>
                <field name="is_fault_blocked"/>
                <field name="location_id" domain="[('usage', '=', 'internal')]"/>
            </list>
        </field>
    </record>

    <!-- Vending Slot: Form View -->
    <record id="view_vending_slot_form" model="ir.ui.view">
        <field name="name">vending.slot.form</field>
        <field name="model">vending.slot</field>
        <field name="arch" type="xml">
            <form string="Slot de Expendedora">
                <field name="is_fault_blocked" invisible="1"/>
                <div class="alert alert-danger" role="alert" invisible="not is_fault_blocked">
                    <strong>Slot desactivado por falla.</strong>
                </div>
                <sheet>
                    <group>
                        <group>
                            <field name="machine_id"/>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="product_tmpl_id"/>
                        </group>
                        <group>
                            <field name="is_fault_blocked" readonly="1"/>
                            <field name="location_id" domain="[('usage', '=', 'internal')]"/>
                        </group>
                    </group>
                    <group string="Stock Information">
                        <field name="current_stock" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action: Vending Slots -->
    <record id="action_vending_slots" model="ir.actions.act_window">
        <field name="name">Vending Slots</field>
        <field name="res_model">vending.slot</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_vending_slot_list"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first vending slot</p>
        </field>
    </record>
</odoo>
