<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Extender stock.warehouse para mostrar máquinas vending -->
    <record id="stock_warehouse_form_vending" model="ir.ui.view">
        <field name="name">stock.warehouse.form.vending</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Expendedora" name="vending_info">
                    <group>
                        <field name="vending_machine_id" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
